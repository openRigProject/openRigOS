# openRigOS base packages — installed on ALL targets

# Core system
sudo
dbus
udev

# SSH
openssh-server
openssh-client

# mDNS — avahi advertises <hostname>.local
# Pre-provisioning: openrig-config.local
# Post-provisioning: <callsign>-<device-type>.local
avahi-daemon
libnss-mdns

# Networking
iproute2
iputils-ping
net-tools
hostapd
dnsmasq
wpasupplicant
isc-dhcp-client
wireless-tools
iw
rfkill
wireless-regdb

# TLS / package management
ca-certificates
apt-utils
apt-transport-https
gnupg

# Ham radio core library (rig control) + rigctld daemon
# libhamlib-utils is pinned to Debian via etc/apt/preferences.d/hamlib
# to avoid version conflicts with the RPi Foundation repo.
libhamlib4
libhamlib-utils

# Serial port support (radio CAT control, TNC, etc.)
minicom

# Config / system utilities
jq
curl
wget
rsync
htop
tmux
vim-tiny
less
